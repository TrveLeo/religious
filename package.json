{
  "name": "devocional-diario-ig",
  "version": "1.0.0",
  "private": true,
  "description": "Gerador de imagem diária do devocional para publicação no Instagram",
  "scripts": {
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "vitest run --config vitest.backend.config.js",
    "test:frontend": "vitest run --config vitest.frontend.config.js",
    "test:backend:cov": "vitest run --config vitest.backend.config.js --coverage",
    "test:frontend:cov": "vitest run --config vitest.frontend.config.js --coverage",
    "generate-site": "node scripts/generate-site.js",
    "generate-og-image": "node scripts/generate-og-image.js",
    "generate-image": "node scripts/generate-image.js",
    "post-instagram": "node scripts/post-instagram.js",
    "generate-game-images": "node scripts/generate-game-images.js",
    "post-game-instagram": "node scripts/post-game-instagram.js",
    "fetch-insights": "node scripts/fetch-insights.js",
    "generate-story": "node scripts/generate-story.js",
    "post-story-instagram": "node scripts/post-story-instagram.js",
    "generate-quote-card": "node scripts/generate-quote-card.js",
    "post-quote-instagram": "node scripts/post-quote-instagram.js",
    "generate-trivia": "node scripts/generate-trivia.js",
    "post-trivia-instagram": "node scripts/post-trivia-instagram.js",
    "generate-reel": "node scripts/generate-reel.js",
    "post-reel-instagram": "node scripts/post-reel-instagram.js",
    "generate-impact-card": "node scripts/generate-impact-card.js",
    "post-impact-instagram": "node scripts/post-impact-instagram.js",
    "generate-reveal": "node scripts/generate-reveal.js",
    "post-reveal-instagram": "node scripts/post-reveal-instagram.js",
    "generate-weekly-plan": "node scripts/generate-weekly-plan.js",
    "post-weekly-plan-instagram": "node scripts/post-weekly-plan-instagram.js",
    "generate-poll-card": "node scripts/generate-poll-card.js",
    "post-poll-instagram": "node scripts/post-poll-instagram.js",
    "generate-ab-story": "node scripts/generate-ab-story.js",
    "post-ab-story-instagram": "node scripts/post-ab-story-instagram.js",
    "post-threads": "node scripts/post-threads.js",
    "fetch-click-stats": "node scripts/fetch-click-stats.js"
  },
  "dependencies": {
    "canvas": "^2.11.2",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.9"
  }
}
